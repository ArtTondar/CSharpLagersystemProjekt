@page "/products"
@using Lagersystem.Blazor.Models.Dtos

<PageTitle>Product</PageTitle>

<div class="outer-container">
    <h4>Produkt Oversigt</h4>

    @if (HasError)
    {
        <div class="alert alert-danger mt-3">
            @ErrorMessage
        </div>
    }

    @if (IsLoading)
    {
        <div class="mt-3">
            <em>Henter produkter...</em>
        </div>
    }

    <div class="mb-3">
        <button class="btn btn-outline-primary me-2"
                @onclick="ReloadProductsAsync"
                disabled="@IsLoading">
            Genindlæs produkter
        </button>

        <button class="btn btn-success"
                @onclick="OpenCreateProductPage">
            Opret produkt
        </button>
    </div>

    <div class="table-container">
        <table class="table table-striped table-hover">
            <thead class="table-primary">
                <tr>
                    <th>Name</th>
                    <th>Description</th>
                    <th>UnitPrice</th>
                    <th>Size</th>
                    <th>Warehouse</th>
                    <th>UnitStock</th>
                    <th>UnitStatus</th>
                    <th>Edit</th>
                    <th>Delete</th>
                </tr>
            </thead>

            <tbody>
                @if (ShowEmptyMessage)
                {
                    <tr>
                        <td colspan="9">Ingen produkter fundet.</td>
                    </tr>
                }
                else
                {
                    @foreach (ProductDto product in Products)
                    {
                        <tr>
                            <td>@product.Name</td>
                            <td>@product.Description</td>
                            <td>@product.UnitPrice</td>
                            <td>@product.Size</td>
                            <td>@product.Warehouse</td>
                            <td>@product.UnitStock</td>
                            <td>@product.UnitStatus</td>
                            <td>
                                <button class="btn btn-sm btn-primary"
                                        @onclick="() => OpenProduct(product.Id)">
                                    Vælg
                                </button>
                            </td>
                            <td>
                                <button class="btn btn-sm btn-danger"
                                        @onclick="() => DeleteProductAsync(product.Id)"
                                        disabled="@IsLoading">
                                    Slet
                                </button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>