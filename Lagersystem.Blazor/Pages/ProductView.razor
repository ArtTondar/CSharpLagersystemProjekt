@page "/product"
@using Lagersystem.Blazor.Models.Dtos

<PageTitle>Product</PageTitle>

<div class="outer-container">
    <!-- Page Header -->
    <h4>Produkt Oversigt</h4>

    <!-- Filter and Action Bar -->
    <div class="row product-filters mb-3">

        <!-- Sort Field -->
        <div class="col-3">
            <select class="form-select" @bind="SortField">
                <option value="Name">Name</option>
                <option value="Description">Description</option>
                <option value="UnitPrice">UnitPrice</option>
                <option value="Size">Size</option>
                <option value="Warehouse">Warehouse</option>
                <option value="UnitStock">UnitStock</option>
                <option value="UnitStatus">UnitStatus</option>
            </select>
        </div>

        <!-- Search Input -->
        <div class="col-5">
            <input class="form-control"
                   placeholder="Søg efter produktnavn..."
                   @bind="SearchTerm"
                   @bind:event="oninput" />
        </div>

        <!-- Sort Direction Button -->
        <div class="col-2">
            <button class="btn btn-outline-secondary w-100" @onclick="ToggleSortDirection">
                @(SortDescending ? "Faldende" : "Stigende")
            </button>
        </div>

        <!-- Create New Product Button -->
        <div class="col-2">
            <button class="btn btn-primary w-100" @onclick="StartCreate">
                Nyt produkt
            </button>
        </div>
    </div>

    <!-- Loading State -->
    @if (IsLoading)
    {
        <p>Indlæser produkter...</p>
    }
    else
    {
        <!-- Product Table -->
        <div class="table-container mb-4">
            <table class="table table-striped table-hover">
                <thead class="table-primary">
                    <tr>
                        <th>Name</th>
                        <th>Description</th>
                        <th>UnitPrice</th>
                        <th>Size</th>
                        <th>Warehouse</th>
                        <th>UnitStock</th>
                        <th>UnitStatus</th>
                        <th>Handlinger</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (ProductDto product in Products)
                    {
                        <tr>
                            <!-- Product Data -->
                            <td>@product.Name</td>
                            <td>@product.Description</td>
                            <td>@product.UnitPrice</td>
                            <td>@product.Size</td>
                            <td>@product.Warehouse</td>
                            <td>@product.UnitStock</td>
                            <td>@product.UnitStatus</td>

                            <!-- Row Actions -->
                            <td>
                                <button class="btn btn-sm btn-warning me-2"
                                        @onclick="() => StartEdit(product)">
                                    Redigér
                                </button>

                                <button class="btn btn-sm btn-danger"
                                        @onclick="() => DeleteAsync(product.Id)">
                                    Slet
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <!-- Product Form Card -->
    <div class="card p-3">
        <h5>@(IsEditMode ? "Redigér produkt" : "Opret produkt")</h5>

        <!-- Product Form Fields -->
        <div class="row g-3">

            <!-- Product Name -->
            <div class="col-md-6">
                <label class="form-label">Navn</label>
                <input class="form-control" @bind="Form.Name" />
            </div>

            <!-- Product Description -->
            <div class="col-md-6">
                <label class="form-label">Beskrivelse</label>
                <input class="form-control" @bind="Form.Description" />
            </div>

            <!-- Product Price -->
            <div class="col-md-4">
                <label class="form-label">Pris</label>
                <input class="form-control" type="number" step="0.01" @bind="Form.UnitPrice" />
            </div>

            <!-- Product Size -->
            <div class="col-md-4">
                <label class="form-label">Størrelse</label>
                <input class="form-control" type="number" @bind="Form.Size" />
            </div>

            <!-- Product Warehouse -->
            <div class="col-md-4">
                <label class="form-label">Lager</label>
                <input class="form-control" @bind="Form.Warehouse" />
            </div>

            <!-- Product Stock -->
            <div class="col-md-4">
                <label class="form-label">Antal på lager</label>
                <input class="form-control" type="number" @bind="Form.UnitStock" />
            </div>

            <!-- Product Status -->
            <div class="col-md-4">
                <label class="form-label">Status</label>
                <select class="form-select" @bind="Form.UnitStatus">
                    @foreach (UnitStatus status in Enum.GetValues<UnitStatus>())
                    {
                        <option value="@status">@status</option>
                    }
                </select>
            </div>
        </div>

        <!-- Form Action Buttons -->
        <div class="mt-3">
            <button class="btn btn-success me-2" @onclick="SaveAsync">
                Gem
            </button>

            <button class="btn btn-secondary" @onclick="StartCreate">
                Nulstil
            </button>
        </div>
    </div>
</div>