@page "/login"

<PageTitle>Login</PageTitle>

<div class="login-page">

    <div class="login-container">

        <h2 class="login-title">Login</h2>
        <p class="login-subtitle">Login for at fortsætte</p>

        <!-- Username -->
        <div class="login-field">
            <label>Brugernavn</label>
            <input class="form-control" placeholder="Indtast brugernavn" />
        </div>

        <!-- Password -->
        <div class="login-field">
            <label>Kodeord</label>
            <input type="password" class="form-control" placeholder="Indtast kodeord" />
        </div>

        <!-- Button Logic -->
        <button class="btn btn-primary login-button">
            Login
        </button>

        <p class="login-footer">
            Lagersystem
        </p>

    </div>

</div>