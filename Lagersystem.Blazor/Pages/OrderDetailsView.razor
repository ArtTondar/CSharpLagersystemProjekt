@page "/order/{Id:guid}"
@using Lagersystem.Blazor.Models.Dtos
@inject Lagersystem.Blazor.State.OrderState OrderState
@inject NavigationManager NavigationManager

<PageTitle>Ordre Detaljer</PageTitle>

<div class="outer-container">
    <!-- Page Header -->
    <h4>Ordre Detaljer</h4>

    <!-- Navigation Buttons -->
    <div class="mb-3">
        <button class="btn btn-secondary" @onclick="GoBack">
            Tilbage til ordreoversigt
        </button>
    </div>

    <!-- Loading State -->
    @if (OrderState.IsLoading)
    {
        <p>Indlæser ordre...</p>
    }
    else if (OrderState.SelectedOrderDetails is null)
    {
        <div class="alert alert-warning">
            Ordren blev ikke fundet.
        </div>
    }
    else
    {
        <!-- Order Summary -->
        <div class="card p-3 mb-4">
            <h5>Ordreinformation</h5>

            <div class="row">
                <div class="col-md-4">
                    <strong>Ordre ID:</strong><br />
                    @OrderState.SelectedOrderDetails.Id
                </div>

                <div class="col-md-4">
                    <strong>Kunde ID:</strong><br />
                    @OrderState.SelectedOrderDetails.CustomerId
                </div>

                <div class="col-md-4">
                    <strong>Ordredato:</strong><br />
                    @OrderState.SelectedOrderDetails.OrderDate.ToString("dd-MM-yyyy")
                </div>
            </div>

            <div class="mt-3">
                <strong>Totalpris:</strong> @OrderState.SelectedOrderDetails.TotalPrice
            </div>
        </div>

        <!-- Order Products Table -->
        <div class="card p-3">
            <h5>Produkter i ordren</h5>

            @if (!OrderState.SelectedOrderDetails.OrderLines.Any())
            {
                <p>Denne ordre har ingen produkter endnu.</p>
            }
            else
            {
                <table class="table table-striped table-hover">
                    <thead class="table-primary">
                        <tr>
                            <th>Produkt</th>
                            <th>Antal</th>
                            <th>Pris</th>
                            <th>Status</th>
                            <th>Linjetotal</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (OrderLineDto line in OrderState.SelectedOrderDetails.OrderLines)
                        {
                            <tr>
                                <td>@line.ProductName</td>
                                <td>@line.Quantity</td>
                                <td>@line.UnitPrice</td>
                                <td>@line.ProductStatus</td>
                                <td>@line.LineTotal</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    }
</div>

@code {
    [Parameter]
    public Guid Id { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        await OrderState.LoadOrderDetailsByIdAsync(Id);
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/order");
    }
}