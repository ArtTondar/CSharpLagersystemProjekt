@page "/orders"
@using Lagersystem.Blazor.Models.Dtos

<PageTitle>Order</PageTitle>

<div class="outer-container">

    <h4>Ordre Oversigt</h4>

    <div class="row filter-labels">
        <div class="col-2">
            <small class="text-muted">Ordre data fra API</small>
        </div>

        <div class="col-8"></div>

        <div class="col-2">
            <small class="text-muted">Hent alle ordrer</small>
        </div>
    </div>

    @if (SelectedOrder is not null)
    {
        <div class="mt-4 mb-4">
            <h5>Valgt ordre</h5>

            <div class="card p-3">
                <p><strong>Id:</strong> @SelectedOrder.Id</p>
                <p><strong>Kunde:</strong> @GetCustomerDisplayName(SelectedOrder.CustomerId)</p>
                <p><strong>CustomerId:</strong> @SelectedOrder.CustomerId</p>
                <p><strong>OrderDate:</strong> @SelectedOrder.OrderDate</p>
                <p><strong>TotalPrice:</strong> @SelectedOrder.TotalPrice</p>
                <p><strong>Antal orderlinjer:</strong> @SelectedOrder.OrderDetails.Count</p>

                @if (SelectedOrder.OrderDetails.Count > 0)
                {
                    <div class="mt-3">
                        <h6>Ordredetaljer</h6>

                        <table class="table table-sm table-striped">
                            <thead>
                                <tr>
                                    <th>ProductId</th>
                                    <th>Quantity</th>
                                    <th>UnitPrice</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (OrderDetailDto detail in SelectedOrder.OrderDetails)
                                {
                                    <tr>
                                        <td>@detail.ProductId</td>
                                        <td>@detail.Quantity</td>
                                        <td>@detail.UnitPrice</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }

                <div class="mt-3">
                    <button class="btn btn-outline-warning"
                            @onclick="UpdateSelectedOrderAsync"
                            disabled="@IsLoading">
                        Test opdatering af valgt ordre
                    </button>
                </div>
            </div>
        </div>
    }

    <button class="btn btn-success"
            @onclick="OpenCreateOrderPage">
        Opret ordre
    </button>

    <div class="row order-filters">
        <div class="col-8"></div>

        <div class="col-4">
            <button class="btn btn-outline-primary w-100"
                    @onclick="ReloadOrdersAsync"
                    disabled="@IsLoading">
                Genindlæs ordrer
            </button>
        </div>
    </div>

    @if (HasError)
    {
        <div class="alert alert-danger mt-3">
            @ErrorMessage
        </div>
    }

    @if (IsLoading)
    {
        <div class="mt-3">
            <em>Henter ordrer...</em>
        </div>
    }

    <div class="table-container mt-3">
        <table class="table table-striped table-hover">
            <thead class="table-primary">
                <tr>
                    <th>Kunde</th>
                    <th>OrderDate</th>
                    <th>TotalPrice</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody>
                @if (ShowEmptyMessage)
                {
                    <tr>
                        <td colspan="4">Ingen ordrer fundet.</td>
                    </tr>
                }
                else
                {
                    @foreach (OrderDto order in Orders)
                    {
                        <tr>
                            <td>@GetCustomerDisplayName(order.CustomerId)</td>
                            <td>@order.OrderDate</td>
                            <td>@order.TotalPrice</td>
                            <td>
                                <button class="btn btn-sm btn-outline-primary me-1"
                                        @onclick="() => SelectOrderAsync(order)">
                                    Vælg
                                </button>

                                <button class="btn btn-sm btn-outline-danger"
                                        @onclick="() => DeleteOrderAsync(order.Id)"
                                        disabled="@IsLoading">
                                    Slet
                                </button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

</div>