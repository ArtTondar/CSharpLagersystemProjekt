@page "/orders"
@using Lagersystem.Blazor.Models.Dtos

<PageTitle>Order</PageTitle>

<div class="outer-container">

    <!-- Side titel -->
    <h4>Ordre Oversigt</h4>

    <!-- Kort info-række -->
    <div class="row filter-labels">

        <div class="col-2">
            <!-- Viser at tabellen henter ordredata fra API'et -->
            <small class="text-muted">Ordre data fra API</small>
        </div>

        <div class="col-8"></div>

        <div class="col-2">
            <!-- Viser at knappen bruges til at hente alle ordrer igen -->
            <small class="text-muted">Hent alle ordrer</small>
        </div>

    </div>

    <!-- Simpel handlingsrække -->
    <div class="row order-filters">

        <div class="col-8"></div>

        <div class="col-4">
            <button class="btn btn-outline-primary w-100"
                    @onclick="ReloadOrdersAsync"
                    disabled="@IsLoading">
                Genindlæs ordrer
            </button>
        </div>

    </div>

    <!-- Fejlbesked hvis API-kald fejler -->
    @if (HasError)
    {
        <div class="alert alert-danger mt-3">
            @ErrorMessage
        </div>
    }

    <!-- Loading-besked mens data hentes -->
    @if (IsLoading)
    {
        <div class="mt-3">
            <em>Henter ordrer...</em>
        </div>
    }

    <!-- Ordre tabel -->
    <div class="table-container mt-3">

        <table class="table table-striped table-hover">

            <thead class="table-primary">
                <tr>
                    <th>CustomerId</th>
                    <th>OrderDate</th>
                    <th>TotalPrice</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody>

                <!-- Vises hvis listen er tom -->
                @if (ShowEmptyMessage)
                {
                    <tr>
                        <td colspan="4">Ingen ordrer fundet.</td>
                    </tr>
                }
                else
                {
                    <!-- Udskriver alle ordrer fra API'et -->
                    @foreach (OrderDto order in Orders)
                    {
                        <tr>
                            <td>@order.CustomerId</td>
                            <td>@order.OrderDate</td>
                            <td>@order.TotalPrice</td>
                            <td>
                                <button class="btn btn-sm btn-outline-primary me-1"
                                        @onclick="() => SelectOrderAsync(order)">
                                    Vælg
                                </button>

                                <button class="btn btn-sm btn-outline-danger"
                                        @onclick="() => DeleteOrderAsync(order.Id)"
                                        disabled="@IsLoading">
                                    Slet
                                </button>
                            </td>
                        </tr>
                    }
                }

            </tbody>

        </table>

    </div>
    @if (SelectedOrder is not null)
    {
        <div class="mt-3">
            <button class="btn btn-outline-warning"
                    @onclick="UpdateSelectedOrderAsync"
                    disabled="@IsLoading">
                Test opdatering af valgt ordre
            </button>
        </div>
    }
    <!-- Simpel visning af valgt ordre -->
    @if (SelectedOrder is not null)
    {
        <div class="mt-4">
            <h5>Valgt ordre</h5>

            <div class="card p-3">
                <p><strong>Id:</strong> @SelectedOrder.Id</p>
                <p><strong>CustomerId:</strong> @SelectedOrder.CustomerId</p>
                <p><strong>OrderDate:</strong> @SelectedOrder.OrderDate</p>
                <p><strong>TotalPrice:</strong> @SelectedOrder.TotalPrice</p>
                <p><strong>Antal orderlinjer:</strong> @SelectedOrder.OrderDetails.Count</p>
            </div>
        </div>
    }

</div>