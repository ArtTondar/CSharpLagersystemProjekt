@page "/order"
@using Lagersystem.Blazor.Models.Dtos

<PageTitle>Order</PageTitle>

<div class="outer-container">
    <!-- Page Header -->
    <h4>Ordre Oversigt</h4>

    <!-- Action Bar -->
    <div class="mb-3">
        <button class="btn btn-primary" @onclick="StartCreate">
            Ny ordre
        </button>
    </div>

    <!-- Loading State -->
    @if (IsLoading)
    {
        <p>Indlæser ordrer...</p>
    }
    else
    {
        <!-- Order Table -->
        <div class="table-container mb-4">
            <table class="table table-striped table-hover">
                <thead class="table-primary">
                    <tr>
                        <th>CustomerId</th>
                        <th>OrderDate</th>
                        <th>TotalPrice</th>
                        <th>Handlinger</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (OrderDto order in Orders)
                    {
                        <tr>
                            <!-- Order Data -->
                            <td>@order.CustomerId</td>
                            <td>@order.OrderDate.ToString("dd-MM-yyyy")</td>
                            <td>@order.TotalPrice</td>

                            <!-- Row Actions -->
                            <td>
                                <button class="btn btn-sm btn-info me-2"
                                        @onclick="() => ViewOrder(order.Id)">
                                    Se ordre
                                </button>

                                <button class="btn btn-sm btn-warning me-2"
                                        @onclick="() => StartEdit(order)">
                                    Redigér
                                </button>

                                <button class="btn btn-sm btn-danger"
                                        @onclick="() => DeleteAsync(order.Id)">
                                    Slet
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <!-- Order Form Card -->
    <div class="card p-3">
        <h5>@(IsEditMode ? "Redigér ordre" : "Opret ordre")</h5>

        <!-- Order Form Fields -->
        <div class="row g-3">

            <!-- Customer Id -->
            <div class="col-md-6">
                <label class="form-label">CustomerId</label>
                <input class="form-control" @bind="Form.CustomerId" />
            </div>

            <!-- Total Price -->
            <div class="col-md-6">
                <label class="form-label">Totalpris</label>
                <input class="form-control" type="number" step="0.01" @bind="Form.TotalPrice" />
            </div>
        </div>

        <!-- Form Action Buttons -->
        <div class="mt-3">
            <button class="btn btn-success me-2" @onclick="SaveAsync">
                Gem
            </button>

            <button class="btn btn-secondary" @onclick="StartCreate">
                Nulstil
            </button>
        </div>
    </div>
</div>