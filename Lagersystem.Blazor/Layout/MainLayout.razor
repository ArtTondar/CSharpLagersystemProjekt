@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4 d-flex justify-content-end align-items-center gap-2">
            @if (AuthState.IsLoggedIn)
            {
                <span class="fw-semibold">
                    @AuthState.DisplayName (@AuthState.Role)
                </span>
            }

            <button type="button"
                    class="btn btn-primary"
                    @onclick="OpenLoginModal">
                @(AuthState.IsLoggedIn ? "Bruger" : "Login")
            </button>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<LoginModal IsVisible="@IsLoginModalOpen" OnClose="CloseLoginModal" />